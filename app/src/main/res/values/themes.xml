<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="Theme.Risotto" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- ── Brand colors ── -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorSecondaryVariant">@color/brand_secondary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>

        <!-- ── Surface ─── -->
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/surface_background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- ── Status bar ── -->
        <item name="android:statusBarColor">@color/surface_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- ── Typography ── -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- ── Shape ── -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Risotto.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Risotto.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Risotto.Large</item>

        <!-- ── TextInputLayout ── -->
        <item name="textInputStyle">@style/Widget.Risotto.TextInputLayout</item>

    </style>

    <!-- ── TextInputLayout — adapts to light/dark via Material 3 surface roles ── -->
    <style name="Widget.Risotto.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <!-- Stroke: grey at rest, brand orange when focused -->
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <!-- Floating label: grey at rest, brand orange when focused -->
        <item name="hintTextColor">@color/text_input_hint</item>
        <!-- Let Material 3 handle box background automatically (adapts to dark mode) -->
        <item name="boxBackgroundMode">outline</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Risotto.Small</item>
    </style>

    <!-- ── Splash theme — shown before RisottoApp.onCreate ── -->
    <style name="Theme.Risotto.Splash" parent="Theme.Risotto">
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/brand_primary</item>
    </style>

    <!-- ── Shape appearances ── -->
    <style name="ShapeAppearance.Risotto.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Risotto.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Risotto.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ── AppBar — standard 4dp elevation per Material spec ── -->
    <style name="Widget.Risotto.AppBar" parent="Widget.Material3.AppBarLayout">
        <item name="elevation">4dp</item>
        <item name="android:background">@color/surface_card</item>
    </style>

    <!-- ── BottomNavigationView ── -->
    <style name="Widget.Risotto.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>