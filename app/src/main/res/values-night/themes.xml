<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="Theme.Risotto" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- ── Brand colors — stay the same in dark mode ── -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- ── Surface — dark overrides ── -->
        <item name="colorSurface">@color/surface_card_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="android:colorBackground">@color/surface_background_dark</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>

        <!-- ── Status bar — dark ── -->
        <item name="android:statusBarColor">@color/surface_background_dark</item>
        <item name="android:windowLightStatusBar">false</item>

    </style>

</resources>