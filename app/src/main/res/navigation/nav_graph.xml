<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- ── Splash ── -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.risotto.presentation.auth.views.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">

        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ── Login ── -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.risotto.presentation.auth.views.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ── Register ── -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.risotto.presentation.auth.views.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ── Home ── -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.risotto.presentation.home.views.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_mealDetail"
            app:destination="@id/mealDetailFragment" />

        <action
            android:id="@+id/action_home_to_allCategories"
            app:destination="@id/allCategoriesFragment" />

        <action
            android:id="@+id/action_home_to_categoryMeals"
            app:destination="@id/categoryMealsFragment" />

    </fragment>

    <!-- ── Categories ── -->
    <fragment
        android:id="@+id/allCategoriesFragment"
        android:name="com.example.risotto.presentation.categories.views.AllCategoriesFragment"
        android:label="@string/home_categories"
        tools:layout="@layout/fragment_all_categories">

        <action
            android:id="@+id/action_allCategories_to_categoryMeals"
            app:destination="@id/categoryMealsFragment" />

    </fragment>

    <!-- ── Category Meals ── -->
    <fragment
        android:id="@+id/categoryMealsFragment"
        android:name="com.example.risotto.presentation.categories.views.CategoryMealsFragment"
        android:label="Category Meals"
        tools:layout="@layout/fragment_category_meals">

        <argument
            android:name="categoryName"
            app:argType="string" />

    </fragment>

    <!-- ── Search ── -->
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.risotto.presentation.search.views.SearchFragment"
        android:label="@string/nav_search"
        tools:layout="@layout/fragment_search" />

    <!-- ── Favorites ── -->
    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.risotto.presentation.favorites.views.FavoritesFragment"
        android:label="@string/nav_favorites"
        tools:layout="@layout/fragment_favorites" />

    <!-- ── Meal Detail ── -->
    <fragment
        android:id="@+id/mealDetailFragment"
        android:name="com.example.risotto.presentation.mealdetail.views.MealDetailFragment"
        android:label="@string/detail_title"
        tools:layout="@layout/fragment_meal_detail">

        <argument
            android:name="mealId"
            app:argType="string" />
        <argument
            android:name="mealName"
            app:argType="string"
            android:defaultValue="" />

    </fragment>

    <!-- ── Settings ── -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.risotto.presentation.settings.views.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings" />

</navigation>