<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.risotto.presentation.home.views.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_mealDetail"
            app:destination="@id/mealDetailFragment" />

    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.risotto.presentation.search.view.SearchFragment"
        android:label="@string/nav_search"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.risotto.presentation.favorites.view.FavoritesFragment"
        android:label="@string/nav_favorites"
        tools:layout="@layout/fragment_favorites" />

    <fragment
        android:id="@+id/mealDetailFragment"
        android:name="com.example.risotto.presentation.mealdetail.views.MealDetailFragment"
        android:label="@string/detail_title"
        tools:layout="@layout/fragment_meal_detail">

        <argument
            android:name="mealId"
            app:argType="string" />
        <argument
            android:name="mealName"
            app:argType="string"
            android:defaultValue="" />

    </fragment>
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.risotto.presentation.settings.view.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings" />

</navigation>