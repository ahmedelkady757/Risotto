<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="40dp"
    android:background="@color/surface_background">

    <!-- Lock icon -->
    <ImageView
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_lock"
        android:alpha="0.6"
        app:tint="@color/brand_primary"
        android:contentDescription="" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/locked_title"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="36dp"
        android:text="@string/locked_message"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <!-- Sign In button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_locked_login"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="@string/locked_btn_login"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="14dp" />

    <!-- Create Account button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_locked_signup"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/locked_btn_signup"
        android:textColor="@color/brand_primary"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="1dp"
        app:cornerRadius="14dp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</LinearLayout>
